---
---

<!-- Fixed header: logo top-left + nav with brackets top-right -->
<header id="site-header" class="fixed z-50" style="top: 7vw; left: calc(8% + 1rem);">
  <div class="flex items-baseline gap-8">
    <!-- Logo -->
    <a id="logo-link" href="/portfolio/" class="tracking-wide no-underline inline-block px-6 py-4 -mx-6 -my-4 font-mono" style="font-size: clamp(1.2rem, 1.8vw, 2rem); transform-style: preserve-3d; will-change: transform;">
      <span class="font-bold text-charcoal">PhuvatatDev</span><span class="text-pop-yellow font-bold">.</span>
    </a>
    <!-- Navigation with brackets -->
    <nav id="main-nav" class="hidden lg:flex gap-4 font-mono" style="font-size: clamp(0.7rem, 0.9vw, 0.85rem); letter-spacing: 0.05em;">
      <a href="#my-work" class="nav-link text-charcoal/60 hover:text-charcoal transition-colors no-underline">[ work ]</a>
      <a href="#my-work" class="nav-link text-charcoal/60 hover:text-charcoal transition-colors no-underline" data-scroll-target="panel-about">[ about ]</a>
      <a href="#contact-section" class="nav-link text-charcoal/60 hover:text-charcoal transition-colors no-underline">[ contact ]</a>
    </nav>
  </div>
  <!-- Scroll progress bar -->
  <div style="margin-top: 0.4rem; width: 100%; height: 2px; background: rgba(26, 26, 26, 0.1); position: relative;">
    <div id="scroll-progress" style="position: absolute; left: 0%; width: 20%; height: 100%; background: #FFD96A;"></div>
  </div>
</header>
