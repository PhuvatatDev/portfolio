---
// ContactHero — Closing section of the site
//
// Layout (all fixed, contact block as the focal point of the grid warp):
// - Grid warp SVG background, centered on viewport
// - Marquee "What are we building next?" — above contact block, enters from left
// - Contact block (tagline + 2 link rows with icons) — EXACT viewport center
//   - Email row: click-to-copy with feedback
//   - Github row: external link
// - Tech stack marquee — above footer, continuous CSS scroll
// - Footer — bottom
//
// Vertical distribution uses calc(50% + Nrem) relative to CTA center,
// so all gaps stay pixel-stable across viewport heights.
//
// Animations handled in scroll-controller.ts
import Marquee from '../ui/Marquee.astro';
import { techLogos } from '../../data/tech-logos';
import { CONTACT_EMAIL } from '../../data/contact';
---

<section id="contact-section" class="relative z-10" style="height: 150vh;">

  <!-- Grid warp background — centered on viewport (focal point = CTA) -->
  <div id="contact-warp" class="fixed inset-0 flex items-center justify-center z-10 opacity-0 pointer-events-none">
    <img src="/portfolio/images/contact-grid-warp.svg" alt="" aria-hidden="true"
         class="w-full h-full object-cover" loading="lazy" decoding="async" />
  </div>

  <!-- Marquee band — enters from the left (inverse of Hero marquee) -->
  <!-- Positioned by bottom so it stays anchored relative to the CTA center -->
  <div id="contact-marquee-band" class="fixed left-0 z-20 overflow-hidden pointer-events-none opacity-0"
       style="bottom: calc(50% + min(7rem, 12vh)); width: 100vw;">
    <h2 id="contact-marquee-text"
        class="font-serif font-bold text-charcoal whitespace-nowrap text-center"
        style="font-size: clamp(2rem, min(5vw, 8vh), 6rem); line-height: 1.15; will-change: transform; padding: 0.1em 8vw 0.2em;">
      What are we building next?
    </h2>
  </div>

  <!-- Contact block — EXACT viewport center (= grid warp focal point) -->
  <div id="contact-upper"
       class="fixed z-30 opacity-0 pointer-events-none flex flex-col items-center"
       style="top: 50%; left: 50%; transform: translate(-50%, -50%); width: min(90vw, 700px);">

    <!-- Tagline -->
    <p class="font-mono text-charcoal/55 text-center"
       style="font-size: clamp(0.75rem, min(0.95vw, 1.6vh), 1rem); margin-bottom: min(1.75rem, 3vh);">
      Available for freelance projects and full-time roles.
    </p>

    <!-- Contact rows — grid: icon | label | arrow | value -->
    <div class="font-mono text-charcoal/60"
         style="display: grid; grid-template-columns: auto auto auto auto; column-gap: min(1rem, 1.8vh); row-gap: min(1rem, 1.8vh); align-items: center; font-size: clamp(0.85rem, min(1.2vw, 2vh), 1.25rem);">

      <!-- Email row (click to copy) -->
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-charcoal/45">
        <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/>
      </svg>
      <span class="text-charcoal/35 text-right">email</span>
      <span class="text-charcoal/20 text-center">→</span>
      <span id="contact-email"
            class="cursor-pointer inline-flex items-center gap-2 text-charcoal hover:text-pop-yellow transition-colors"
            title="Click to copy">
        {CONTACT_EMAIL}
        <svg id="copy-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <span id="copied-feedback" style="display:none;" class="inline-flex items-center gap-1 text-pop-yellow-deep">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span style="font-size: 0.8em;">Copied</span>
        </span>
      </span>

      <!-- Github row -->
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-charcoal/60">
        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.6.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.5 11.5 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
      </svg>
      <span class="text-charcoal/35 text-right">github</span>
      <span class="text-charcoal/20 text-center">→</span>
      <a href="https://github.com/PhuvatatDev" target="_blank" rel="noopener noreferrer"
         class="text-charcoal hover:text-pop-yellow transition-colors no-underline">github.com/PhuvatatDev</a>

    </div>

  </div>

  <!-- Tech stack marquee — continuous CSS scroll, above footer -->
  <div id="contact-tech-marquee" class="fixed left-0 z-20 opacity-0 pointer-events-none"
       style="bottom: calc(6% + min(2.5rem, 4vh)); width: 100vw;">
    <p class="font-mono text-charcoal/30 text-center"
       style="font-size: clamp(0.55rem, min(0.7vw, 1.1vh), 0.7rem); letter-spacing: 0.08em; margin-bottom: min(0.75rem, 1.3vh);">[ what I use ]</p>
    <Marquee logos={techLogos} speed="90s" repeat={4} />
  </div>

  <!-- Footer — bottom -->
  <div id="contact-footer" class="fixed z-30 opacity-0 pointer-events-none"
       style="bottom: 6%; left: 50%; transform: translateX(-50%);">
    <p class="font-mono text-charcoal/25 text-center"
       style="font-size: clamp(0.5rem, min(0.6vw, 1vh), 0.65rem);">
      © 2026 Phuvatat · Illustrations by <a href="https://storyset.com" target="_blank" rel="noopener noreferrer" class="hover:text-pop-yellow transition-colors no-underline" style="pointer-events: auto;">Storyset</a>
    </p>
  </div>

</section>

<style>
  /* Re-enable pointer-events on marquee logos inside the pointer-events-none wrapper
     so their hover (grayscale → color) still works. The .marquee-logo class lives
     inside the Marquee child component, so we use :global() to pierce scoping. */
  #contact-tech-marquee:hover :global(.marquee-logo) {
    pointer-events: auto;
  }
</style>
