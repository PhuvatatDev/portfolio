---
// ContactHero — Contact section styled like the Hero
// Text left + scattered tech cards right (decorative symmetry with Hero illustrations)
//
// Integration:
// - Placed at the end of the scroll
// - Text + CTA fixed left (same position as Hero tagline)
// - Tech cards scattered on the right (fade in via scroll-controller.ts)
// - scroll-controller.ts handles: fade in text, fade in scattered cards
import TechCard from '../ui/TechCard.astro';
---

<section id="contact-section" class="relative z-10" style="height: 150vh;">

  <!-- Contact text — same position as Hero tagline (fixed, left) -->
  <div id="contact-text" class="fixed z-20 opacity-0 pointer-events-none"
       style="top: 50%; left: 8%; transform: translateY(-50%); max-width: 45%;">

    <p class="font-mono text-charcoal/40 mb-4" style="font-size: clamp(0.65rem, 0.7vw, 0.75rem); letter-spacing: 0.1em;">
      [ contact ]
    </p>

    <h2 class="font-serif font-bold text-charcoal mb-3 leading-tight" style="font-size: clamp(1.8rem, 3vw, 3.2rem);">
      Let's build something.
    </h2>

    <p class="font-mono text-charcoal/50 mb-6" style="font-size: clamp(0.75rem, 0.85vw, 0.9rem);">
      Available for freelance projects and full-time roles.
    </p>

    <!-- Terminal-style links -->
    <div class="font-mono text-charcoal/60 mb-8" style="font-size: clamp(0.8rem, 0.9vw, 0.95rem); line-height: 2.2;">
      <p>
        <span class="text-charcoal/35">email</span>
        <span class="text-charcoal/20 mx-3">→</span>
        <a href="mailto:phuvatat.dev@gmail.com" class="text-charcoal hover:text-pop-yellow transition-colors no-underline">phuvatat.dev@gmail.com</a>
      </p>
      <p>
        <span class="text-charcoal/35">github</span>
        <span class="text-charcoal/20 mx-3">→</span>
        <a href="https://github.com/PhuvatatDev" target="_blank" rel="noopener" class="text-charcoal hover:text-pop-yellow transition-colors no-underline">github.com/PhuvatatDev</a>
      </p>
    </div>

    <!-- CTA -->
    <a href="mailto:phuvatat.dev@gmail.com"
       class="font-mono no-underline inline-block px-6 py-3 bg-pop-yellow text-charcoal font-bold rounded hover:bg-pop-yellow-deep transition-colors"
       style="font-size: clamp(0.8rem, 0.9vw, 0.95rem);">
      [ send a message ]
    </a>

    <!-- Footer -->
    <p class="font-mono text-charcoal/20 mt-16" style="font-size: clamp(0.55rem, 0.6vw, 0.65rem);">
      © 2026 Phuvatat
    </p>

  </div>

  <!-- Scattered tech cards — decorative, right side (mirrors Hero illustrations) -->
  <div id="scattered-cards" class="fixed z-10 opacity-0 pointer-events-none hidden lg:block"
       style="right: 0; top: 0; width: 47vw; height: 100vh;">

    <div class="absolute" style="top: 12vh; right: 18vw; transform: rotate(-3deg);">
      <TechCard title="Clean Architecture" description="data / domain / presentation" featureId="sc-clean" scattered />
    </div>

    <div class="absolute" style="top: 28vh; right: 6vw; transform: rotate(2deg);">
      <TechCard title="AI Integration" description="Gemini 2.5 Flash" featureId="sc-ai" scattered />
    </div>

    <div class="absolute" style="top: 42vh; right: 22vw; transform: rotate(-1deg);">
      <TechCard title="Security" description="App Check + Rules" featureId="sc-security" scattered />
    </div>

    <div class="absolute" style="top: 55vh; right: 10vw; transform: rotate(4deg);">
      <TechCard title="Payments" description="RevenueCat" featureId="sc-payments" scattered />
    </div>

    <div class="absolute" style="top: 20vh; right: 4vw; transform: rotate(-2deg);">
      <TechCard title="Authentication" description="Email, Google, Apple" featureId="sc-auth" scattered />
    </div>

    <div class="absolute" style="top: 68vh; right: 20vw; transform: rotate(1deg);">
      <TechCard title="State Management" description="Cubit / BLoC" featureId="sc-state" scattered />
    </div>

    <div class="absolute" style="top: 75vh; right: 8vw; transform: rotate(-4deg);">
      <TechCard title="Multilingual" description="EN · FR · RU" featureId="sc-i18n" scattered />
    </div>

  </div>

</section>
