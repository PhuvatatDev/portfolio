---
---

<section class="h-screen relative">
  <!-- Hero text, bottom-left -->
  <div id="hero-text" class="fixed top-[28%] lg:top-auto lg:bottom-[15%] left-[8%] z-20 max-w-[90%] lg:max-w-[50%]">
    <!-- Tagline -->
    <h1 class="font-serif font-bold leading-[1.1] tracking-tight text-charcoal mb-6 lg:mb-8 max-w-[85vw] lg:max-w-[35vw]" style="font-size: clamp(2.2rem, 4vw, 4.5rem);">
      I build apps from idea to deployment.
    </h1>
    <!-- Sub-text -->
    <p class="font-mono text-charcoal/50 mb-6" style="font-size: clamp(1.1rem, 1.5vw, 1.4rem); letter-spacing: 0.08em;">
      Your app on every platform.
    </p>
    <div class="flex gap-10 items-center mb-8 lg:mb-10">
      <!-- Apple / iOS -->
      <div class="flex flex-col items-center gap-2">
        <svg class="w-10 h-10 text-charcoal/60" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <span class="font-mono text-charcoal/40" style="font-size: 0.85rem;">iOS</span>
      </div>
      <!-- Android -->
      <div class="flex flex-col items-center gap-2">
        <svg class="w-10 h-10 text-charcoal/60" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.6 9.48l1.84-3.18c.16-.31.04-.69-.27-.86-.31-.16-.69-.04-.86.27l-1.87 3.23C14.79 8.31 13.21 8 12 8s-2.79.31-4.44.94L5.69 5.71c-.16-.31-.54-.43-.86-.27-.31.16-.43.55-.27.86L6.4 9.48C3.3 11.25 1.28 14.44 1 18h22c-.28-3.56-2.3-6.75-5.4-8.52zM7 15.25c-.69 0-1.25-.56-1.25-1.25s.56-1.25 1.25-1.25 1.25.56 1.25 1.25-.56 1.25-1.25 1.25zm10 0c-.69 0-1.25-.56-1.25-1.25s.56-1.25 1.25-1.25 1.25.56 1.25 1.25-.56 1.25-1.25 1.25z"/>
        </svg>
        <span class="font-mono text-charcoal/40" style="font-size: 0.85rem;">Android</span>
      </div>
      <!-- Web -->
      <div class="flex flex-col items-center gap-2">
        <svg class="w-10 h-10 text-charcoal/60" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
        </svg>
        <span class="font-mono text-charcoal/40" style="font-size: 0.85rem;">Web</span>
      </div>
    </div>
  </div>

  <!-- Illustrations — scattered on the right, not in order -->
  <!-- Container: right 47vw like MindTarot cards, with 3D perspective -->
  <div id="hero-illustrations" class="fixed z-30 pointer-events-none" style="right: 0; top: 0; width: 47vw; height: 100vh; perspective: 1200px;">
    <!-- Idea (step 1) — high left -->
    <img
      id="illus-idea"
      src="/portfolio/images/illustrations/step-idea.svg"
      alt=""
      class="absolute"
      style="top: 20vh; right: 20vw; width: 14vw; transform: rotateY(-3deg) rotateX(1deg);"
    />
    <!-- Build (step 3) — middle right, largest -->
    <img
      id="illus-build"
      src="/portfolio/images/illustrations/step-build.svg"
      alt=""
      class="absolute"
      style="top: 38vh; right: 4vw; width: 17vw; transform: rotateY(-4deg) rotateX(2deg);"
    />
    <!-- Discussion (step 2) — middle left -->
    <img
      id="illus-discussion"
      src="/portfolio/images/illustrations/step-discussion.svg"
      alt=""
      class="absolute"
      style="top: 52vh; right: 24vw; width: 13vw; transform: rotateY(-3deg) rotateX(3deg);"
    />
    <!-- Live (step 4) — bottom -->
    <img
      id="illus-live"
      src="/portfolio/images/illustrations/step-live.svg"
      alt=""
      class="absolute"
      style="top: 68vh; right: 12vw; width: 15vw; transform: rotateY(-5deg) rotateX(2deg);"
    />
  </div>
</section>
