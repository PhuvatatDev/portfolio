---
---

<section id="hero" class="relative" style="height: 100vh;">

  <!-- Marquee — full-viewport horizontal band, centered vertically -->
  <!-- z-10: BELOW the illustrations (z-30) so they pass on top -->
  <div id="hero-marquee" class="fixed left-0 overflow-hidden pointer-events-none z-10"
       style="top: 50%; transform: translateY(-50%); width: 100vw;">
    <h1 id="hero-marquee-text"
        class="font-serif font-bold leading-none text-charcoal whitespace-nowrap"
        style="font-size: clamp(5rem, 13vw, 18rem); will-change: transform; padding-left: 8vw; padding-bottom: 0.15em;">
      I build apps from idea to <span id="hero-last-word">deployment.</span>
    </h1>
  </div>

  <!-- Bottom-left block: sub-text logos + CTAs -->
  <!-- z-20: above marquee, below illustrations -->
  <div id="hero-bottom-left" class="fixed z-20"
       style="left: 8%; bottom: 10%; max-width: 50%;">

    <!-- Sub-text with logos -->
    <div class="flex items-center gap-4 mb-6 font-mono text-charcoal/50"
         style="font-size: clamp(1rem, 1.4vw, 1.3rem); letter-spacing: 0.08em;">
      <span class="inline-flex items-center gap-1.5 whitespace-nowrap"><img src="/portfolio/images/logos/flutter-icon.svg" alt="Flutter" class="w-7 h-7" width="28" height="28" loading="eager" decoding="async" fetchpriority="high" />Flutter</span>
      <span>·</span>
      <span class="inline-flex items-center gap-1.5 whitespace-nowrap"><img src="/portfolio/images/logos/firebase.svg" alt="Firebase" class="w-7 h-7" width="28" height="28" loading="eager" decoding="async" fetchpriority="high" />Firebase</span>
      <span>·</span>
      <span class="inline-flex items-center gap-1.5 whitespace-nowrap"><img src="/portfolio/images/logos/typescript.svg" alt="TypeScript" class="w-7 h-7" width="28" height="28" loading="eager" decoding="async" fetchpriority="high" />TypeScript</span>
    </div>

    <!-- CTAs -->
    <div class="flex gap-4 font-mono" style="font-size: clamp(0.85rem, 1vw, 1rem);">
      <a href="#phone-showcase" class="hero-cta hero-cta-primary nav-link no-underline px-6 py-3 bg-pop-yellow text-charcoal font-bold rounded">[ see my work ]</a>
      <a href="#contact-section" class="hero-cta hero-cta-secondary nav-link no-underline px-6 py-3 border border-charcoal/20 text-charcoal/70 rounded">[ get in touch ]</a>
    </div>
  </div>

  <!-- Illustrations — scattered on the right, z-30 so they pass ABOVE the marquee -->
  <div id="hero-illustrations" class="fixed z-30 pointer-events-none" style="right: 0; top: 0; width: 47vw; height: 100vh; perspective: 1200px;">
    <!-- Idea (step 1) — high left -->
    <img
      id="illus-idea"
      src="/portfolio/images/illustrations/step-idea.svg"
      alt=""
      class="absolute"
      style="top: 20vh; right: 20vw; width: 14vw; transform: rotateY(-3deg) rotateX(1deg);"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <!-- Build (step 3) — middle right, largest -->
    <img
      id="illus-build"
      src="/portfolio/images/illustrations/step-build.svg"
      alt=""
      class="absolute"
      style="top: 38vh; right: 4vw; width: 17vw; transform: rotateY(-4deg) rotateX(2deg);"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <!-- Discussion (step 2) — middle left -->
    <img
      id="illus-discussion"
      src="/portfolio/images/illustrations/step-discussion.svg"
      alt=""
      class="absolute"
      style="top: 52vh; right: 24vw; width: 13vw; transform: rotateY(-3deg) rotateX(3deg);"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <!-- Live (step 4) — bottom -->
    <img
      id="illus-live"
      src="/portfolio/images/illustrations/step-live.svg"
      alt=""
      class="absolute"
      style="top: 68vh; right: 12vw; width: 15vw; transform: rotateY(-5deg) rotateX(2deg);"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </div>
</section>

<style>
  /* Hero CTAs — permanent 3D lift effect (same language as store-btn / repo-link) */
  .hero-cta {
    display: inline-block;
    transform: translateY(-3px);
    transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 0.25s,
                background-color 0.25s,
                border-color 0.25s,
                color 0.25s;
    will-change: transform;
    box-shadow:
      0 8px 16px -6px rgba(26, 26, 26, 0.22),
      0 4px 8px -3px rgba(26, 26, 26, 0.12),
      0 2px 4px -1px rgba(26, 26, 26, 0.08);
  }
  .hero-cta:hover {
    transform: translateY(-6px);
    box-shadow:
      0 16px 28px -8px rgba(26, 26, 26, 0.28),
      0 8px 14px -4px rgba(26, 26, 26, 0.16),
      0 3px 6px -1px rgba(26, 26, 26, 0.1);
  }
  .hero-cta-primary:hover {
    background-color: #FFCF4D;
  }
  .hero-cta-secondary:hover {
    border-color: rgba(26, 26, 26, 0.45);
    color: rgba(26, 26, 26, 0.9);
  }
</style>
