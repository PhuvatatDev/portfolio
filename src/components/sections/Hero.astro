---
---

<section class="h-screen relative">
  <!-- Hero text, bottom-left -->
  <div id="hero-text" class="fixed top-[28%] lg:top-[50%] lg:-translate-y-1/2 left-[8%] z-20 max-w-[90%] lg:max-w-[50%]">
    <!-- Tagline -->
    <h1 class="font-serif font-bold leading-[1.1] tracking-tight text-charcoal mb-6 lg:mb-8 max-w-[85vw] lg:max-w-[35vw]" style="font-size: clamp(2.2rem, 4vw, 4.5rem);">
      I build apps from idea to deployment.
    </h1>
    <!-- Sub-text -->
    <div class="flex items-center gap-4 mb-8 lg:mb-10 font-mono text-charcoal/50" style="font-size: clamp(1.1rem, 1.5vw, 1.4rem); letter-spacing: 0.08em;">
      <img src="/portfolio/images/logos/flutter-icon.svg" alt="Flutter" class="w-7 h-7" />Flutter
      <span>·</span>
      <img src="/portfolio/images/logos/firebase.svg" alt="Firebase" class="w-7 h-7" />Firebase
      <span>·</span>
      <img src="/portfolio/images/logos/typescript.svg" alt="TypeScript" class="w-7 h-7" />TypeScript
    </div>
    <!-- CTAs -->
    <div class="flex gap-4 font-mono" style="font-size: clamp(0.85rem, 1vw, 1rem);">
      <a href="#my-work" class="nav-link no-underline px-6 py-3 bg-pop-yellow text-charcoal font-bold rounded hover:bg-pop-yellow-deep transition-colors">[ see my work ]</a>
      <a href="#contact-section" class="nav-link no-underline px-6 py-3 border border-charcoal/20 text-charcoal/70 rounded hover:text-charcoal hover:border-charcoal/40 transition-colors">[ get in touch ]</a>
    </div>
  </div>

  <!-- Illustrations — scattered on the right, not in order -->
  <!-- Container: right 47vw like MindTarot cards, with 3D perspective -->
  <div id="hero-illustrations" class="fixed z-30 pointer-events-none" style="right: 0; top: 0; width: 47vw; height: 100vh; perspective: 1200px;">
    <!-- Idea (step 1) — high left -->
    <img
      id="illus-idea"
      src="/portfolio/images/illustrations/step-idea.svg"
      alt=""
      class="absolute"
      style="top: 20vh; right: 20vw; width: 14vw; transform: rotateY(-3deg) rotateX(1deg);"
    />
    <!-- Build (step 3) — middle right, largest -->
    <img
      id="illus-build"
      src="/portfolio/images/illustrations/step-build.svg"
      alt=""
      class="absolute"
      style="top: 38vh; right: 4vw; width: 17vw; transform: rotateY(-4deg) rotateX(2deg);"
    />
    <!-- Discussion (step 2) — middle left -->
    <img
      id="illus-discussion"
      src="/portfolio/images/illustrations/step-discussion.svg"
      alt=""
      class="absolute"
      style="top: 52vh; right: 24vw; width: 13vw; transform: rotateY(-3deg) rotateX(3deg);"
    />
    <!-- Live (step 4) — bottom -->
    <img
      id="illus-live"
      src="/portfolio/images/illustrations/step-live.svg"
      alt=""
      class="absolute"
      style="top: 68vh; right: 12vw; width: 15vw; transform: rotateY(-5deg) rotateX(2deg);"
    />
  </div>
</section>
