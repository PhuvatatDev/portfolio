---
// AboutSection — Standalone cream card with photo + text
// Own section with scroll height, own fixed card
// Enters from below, stays fixed, exits upward
---

<section id="about-section" class="relative z-10" style="height: 250vh;">

  <!-- Vertical section label — fixed, synced with about-card via GSAP -->
  <div id="about-label" class="section-label-wrapper section-label-card">
    <span class="section-label-vertical">[ about ]</span>
  </div>

  <div id="about-card" class="fixed opacity-0 z-20" style="top: 55%; left: 50%; width: 85vw; max-width: 1100px; background-color: #F5F3EF; border-radius: 1rem; overflow: hidden; padding: 2.5vw 3vw 1.5vw;">

    <div class="flex flex-col lg:flex-row gap-6 items-start">

      <!-- Photo carousel -->
      <div class="shrink-0" style="width: clamp(160px, 16vw, 220px);">
        <div id="about-photo-carousel" class="relative overflow-hidden rounded-lg" style="aspect-ratio: 3/4;">
          <img src="/portfolio/images/photos/office1.webp" alt="Phuvatat — office" class="about-photo absolute inset-0 w-full h-full object-cover" data-index="0" loading="lazy" decoding="async" />
          <img src="/portfolio/images/photos/office2.webp" alt="Phuvatat — working" class="about-photo absolute inset-0 w-full h-full object-cover opacity-0" data-index="1" loading="lazy" decoding="async" />
          <img src="/portfolio/images/photos/casual.webp" alt="Phuvatat — casual" class="about-photo absolute inset-0 w-full h-full object-cover opacity-0" data-index="2" loading="lazy" decoding="async" />

          <!-- Navigation arrows -->
          <button id="photo-prev" class="absolute left-1 top-1/2 -translate-y-1/2 z-10 bg-charcoal/30 hover:bg-charcoal/50 text-white rounded-full flex items-center justify-center transition-colors" style="width: clamp(24px, 2vw, 32px); height: clamp(24px, 2vw, 32px); font-size: clamp(0.7rem, 0.8vw, 0.9rem);">
            ‹
          </button>
          <button id="photo-next" class="absolute right-1 top-1/2 -translate-y-1/2 z-10 bg-charcoal/30 hover:bg-charcoal/50 text-white rounded-full flex items-center justify-center transition-colors" style="width: clamp(24px, 2vw, 32px); height: clamp(24px, 2vw, 32px); font-size: clamp(0.7rem, 0.8vw, 0.9rem);">
            ›
          </button>

          <!-- Dots indicator -->
          <div class="absolute bottom-2 left-1/2 -translate-x-1/2 z-10 flex gap-1.5">
            <span class="photo-dot bg-white rounded-full" style="width: 6px; height: 6px; opacity: 1;"></span>
            <span class="photo-dot bg-white rounded-full" style="width: 6px; height: 6px; opacity: 0.4;"></span>
            <span class="photo-dot bg-white rounded-full" style="width: 6px; height: 6px; opacity: 0.4;"></span>
          </div>
        </div>
      </div>

      <!-- Text -->
      <div class="flex-1">
        <h2 class="font-serif font-bold text-charcoal mb-1" style="font-size: clamp(1.3rem, 1.6vw, 1.8rem);">
          Phuvatat
        </h2>
        <p class="font-mono text-charcoal/40 mb-5" style="font-size: clamp(0.68rem, 0.76vw, 0.82rem);">
          Flutter developer · Self-taught
        </p>

        <div class="font-mono text-charcoal/55 space-y-3" style="font-size: clamp(0.68rem, 0.76vw, 0.82rem); line-height: 1.75;">
          <p>I started building the website for my cleaning business with no-code tools. They didn't let me do what I really wanted. All the no-code and low-code tools, all the courses — they were bad investments that disappointed me. So I decided to learn to code myself, so I could build my own projects.</p>
          <p>It was hard at the beginning. The determination I built from eight years of jiu-jitsu got me through it. I know that learning means producing and moving forward through the failures, layer by layer.</p>
          <p>Over a year later, I have solid experience behind me and an app running in production. Ready for the next project.</p>
        </div>

        <p class="font-mono text-charcoal/30 mt-5" style="font-size: clamp(0.6rem, 0.65vw, 0.7rem);">
          Based in Thailand · Working internationally
        </p>
      </div>

    </div>

  </div>
</section>

<style>
  .about-photo {
    transition: opacity 0.4s ease;
  }
</style>

<script>
  // Photo carousel — prev/next with fade transition
  function initPhotoCarousel() {
    const photos = document.querySelectorAll<HTMLImageElement>('.about-photo');
    const dots = document.querySelectorAll<HTMLSpanElement>('.photo-dot');
    const prevBtn = document.getElementById('photo-prev');
    const nextBtn = document.getElementById('photo-next');

    if (!photos.length || !prevBtn || !nextBtn) return;

    let current = 0;
    const total = photos.length;

    function showPhoto(index: number) {
      photos.forEach((photo, i) => {
        photo.style.opacity = i === index ? '1' : '0';
      });
      dots.forEach((dot, i) => {
        dot.style.opacity = i === index ? '1' : '0.4';
      });
      current = index;
    }

    prevBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      showPhoto((current - 1 + total) % total);
    });

    nextBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      showPhoto((current + 1) % total);
    });
  }

  initPhotoCarousel();
</script>
