---
// RepoSection — Standalone cream card with projects table
// Own section with scroll height, own fixed card
// Enters from below, stays fixed, exits upward
---

<section id="repo-section" class="relative z-10" style="height: 250vh;">

  <!-- Vertical section label — fixed, synced with repo-card via GSAP -->
  <div id="repo-label" class="section-label-wrapper section-label-card">
    <span class="section-label-vertical">[ repositories ]</span>
  </div>

  <div id="repo-card" class="fixed opacity-0 z-20" style="top: 55%; left: 50%; width: 85vw; max-width: 1100px; background-color: #F5F3EF; border-radius: 1rem; overflow: hidden; padding: 2.5vw 3vw 1.5vw;">

    <h2 class="font-serif font-bold text-charcoal mb-5" style="font-size: clamp(1.3rem, 1.6vw, 1.8rem);">
      What I've built
    </h2>

    <!-- Projects table -->
    <div class="overflow-hidden rounded-lg border border-charcoal/10">
      <table class="w-full font-mono" style="font-size: clamp(0.6rem, 0.68vw, 0.73rem);">
        <thead>
          <tr class="bg-charcoal/5 text-left">
            <th class="px-3 py-2 text-charcoal/50 font-normal" style="width: 20%;">Project</th>
            <th class="px-3 py-2 text-charcoal/50 font-normal" style="width: 55%;">Description</th>
            <th class="px-3 py-2 text-charcoal/50 font-normal text-right" style="width: 25%;">Link</th>
          </tr>
        </thead>
        <tbody class="text-charcoal/55">
          <tr class="border-t border-charcoal/8">
            <td class="px-3 py-2.5 font-bold text-charcoal/80">MindTarot</td>
            <td class="px-3 py-2.5">Tarot app with AI interpretations — live on stores</td>
            <td class="px-3 py-2.5 text-right">
              <a href="https://mindtarotapp.com" target="_blank" rel="noopener" class="repo-link">website</a>
              <span class="text-charcoal/15 mx-1">·</span>
              <a href="https://play.google.com/store/apps/details?id=com.pvtdev.mindtarot" target="_blank" rel="noopener" class="repo-link">play</a>
              <span class="text-charcoal/15 mx-1">·</span>
              <a href="https://apps.apple.com/app/mindtarot/id6757782630" target="_blank" rel="noopener" class="repo-link">ios</a>
            </td>
          </tr>
          <tr class="border-t border-charcoal/8">
            <td class="px-3 py-2.5"><a href="https://github.com/PhuvatatDev/study_flutter" target="_blank" rel="noopener" class="font-bold text-charcoal/80 hover:text-pop-yellow transition-colors no-underline">study_flutter</a></td>
            <td class="px-3 py-2.5">Flutter widgets & layouts, written by hand without AI</td>
            <td class="px-3 py-2.5 text-right"><a href="https://github.com/PhuvatatDev/study_flutter" target="_blank" rel="noopener" class="repo-link">github ↗</a></td>
          </tr>
          <tr class="border-t border-charcoal/8">
            <td class="px-3 py-2.5"><a href="https://github.com/PhuvatatDev/dart_algorithm" target="_blank" rel="noopener" class="font-bold text-charcoal/80 hover:text-pop-yellow transition-colors no-underline">dart_algorithm</a></td>
            <td class="px-3 py-2.5">Data structures & algorithms in Dart</td>
            <td class="px-3 py-2.5 text-right"><a href="https://github.com/PhuvatatDev/dart_algorithm" target="_blank" rel="noopener" class="repo-link">github ↗</a></td>
          </tr>
          <tr class="border-t border-charcoal/8">
            <td class="px-3 py-2.5"><a href="https://github.com/PhuvatatDev/chat_app" target="_blank" rel="noopener" class="font-bold text-charcoal/80 hover:text-pop-yellow transition-colors no-underline">chat_app</a></td>
            <td class="px-3 py-2.5">Real-time chat with Firebase Auth & Firestore</td>
            <td class="px-3 py-2.5 text-right"><a href="https://github.com/PhuvatatDev/chat_app" target="_blank" rel="noopener" class="repo-link">github ↗</a></td>
          </tr>
          <tr class="border-t border-charcoal/8">
            <td class="px-3 py-2.5"><a href="https://github.com/PhuvatatDev/lead_magnette" target="_blank" rel="noopener" class="font-bold text-charcoal/80 hover:text-pop-yellow transition-colors no-underline">lead_magnette</a></td>
            <td class="px-3 py-2.5">Marketing landing page for a tarot masterclass</td>
            <td class="px-3 py-2.5 text-right"><a href="https://github.com/PhuvatatDev/lead_magnette" target="_blank" rel="noopener" class="repo-link">github ↗</a></td>
          </tr>
          <tr class="border-t border-charcoal/8">
            <td class="px-3 py-2.5 font-bold text-charcoal/80">la_tarot_academie</td>
            <td class="px-3 py-2.5">Full website for a tarot academy</td>
            <td class="px-3 py-2.5 text-right"><span class="text-charcoal/25" style="font-size: 0.6rem;">private</span></td>
          </tr>
        </tbody>
      </table>
    </div>

  </div>
</section>

<style>
  .repo-link {
    font-family: 'Chivo Mono', monospace;
    color: rgba(26, 26, 26, 0.4);
    text-decoration: none;
    transition: color 0.2s;
  }

  .repo-link:hover {
    color: rgba(26, 26, 26, 0.8);
  }
</style>
