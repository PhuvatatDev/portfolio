---
// My Work — Process Card only
// Illustrations converge into cream card with 4 steps (Idea → Discussion → Build → Live)
// Card exits upward, then phone+tech arrives
---

<section id="my-work" class="relative z-10" style="height: 200vh;">

  <!-- Vertical section label — fixed, synced with process-card via GSAP -->
  <div id="process-label" class="section-label-wrapper section-label-card">
    <span class="section-label-vertical">[ how it works ]</span>
  </div>

  <!-- CreamPanel — FIXED, position managed by GSAP (xPercent/yPercent for centering) -->
  <div id="process-card" class="fixed opacity-0 z-20" style="top: 55%; left: 50%; width: 85vw; max-width: 1100px; background-color: #F5F3EF; border-radius: 1rem; overflow: hidden;">

    <!-- === Panel 1: Process (visible by default) === -->
    <div id="panel-process" style="padding: 2.5vw 3vw 1.5vw;">

      <!-- 4 steps — horizontal row -->
      <div class="flex justify-between items-start gap-4">

      <!-- Step 1: Idea -->
      <div id="process-slot-idea" class="flex flex-col items-center text-center flex-1">
        <div class="process-illus-slot" style="width: 10vw; height: 10vw; max-width: 160px; max-height: 160px;"></div>
        <h3 class="font-serif font-bold text-charcoal mt-3" style="font-size: clamp(0.95rem, 1.1vw, 1.2rem);">Idea</h3>
        <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, 0.7vw, 0.75rem);">You have an app idea</p>
      </div>

      <!-- Arrow -->
      <div class="flex items-center text-charcoal/20" style="font-size: clamp(1rem, 1.5vw, 1.5rem); padding-top: 5vw;">→</div>

      <!-- Step 2: Discussion -->
      <div id="process-slot-discussion" class="flex flex-col items-center text-center flex-1">
        <div class="process-illus-slot" style="width: 10vw; height: 10vw; max-width: 160px; max-height: 160px;"></div>
        <h3 class="font-serif font-bold text-charcoal mt-3" style="font-size: clamp(0.95rem, 1.1vw, 1.2rem);">Discussion</h3>
        <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, 0.7vw, 0.75rem);">We align on scope & goals</p>
      </div>

      <!-- Arrow -->
      <div class="flex items-center text-charcoal/20" style="font-size: clamp(1rem, 1.5vw, 1.5rem); padding-top: 5vw;">→</div>

      <!-- Step 3: Build -->
      <div id="process-slot-build" class="flex flex-col items-center text-center flex-1">
        <div class="process-illus-slot" style="width: 10vw; height: 10vw; max-width: 160px; max-height: 160px;"></div>
        <h3 class="font-serif font-bold text-charcoal mt-3" style="font-size: clamp(0.95rem, 1.1vw, 1.2rem);">Build</h3>
        <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, 0.7vw, 0.75rem);">I turn it into a real app</p>
      </div>

      <!-- Arrow -->
      <div class="flex items-center text-charcoal/20" style="font-size: clamp(1rem, 1.5vw, 1.5rem); padding-top: 5vw;">→</div>

      <!-- Step 4: Live -->
      <div id="process-slot-live" class="flex flex-col items-center text-center flex-1">
        <div class="process-illus-slot" style="width: 10vw; height: 10vw; max-width: 160px; max-height: 160px;"></div>
        <h3 class="font-serif font-bold text-charcoal mt-3" style="font-size: clamp(0.95rem, 1.1vw, 1.2rem);">Live</h3>
        <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, 0.7vw, 0.75rem);">Published on the stores</p>
      </div>

    </div>

    <!-- Tech stack label + marquee -->
    <p class="font-mono text-charcoal/30 mt-6 border-t border-charcoal/10 pt-4 mb-3" style="font-size: clamp(0.6rem, 0.7vw, 0.7rem); letter-spacing: 0.08em;">[ what I use ]</p>
    <div class="marquee-container">
      <div class="marquee-track">
        <div class="marquee-set">
          <img src="/portfolio/images/logos/flutter.svg" alt="Flutter" class="marquee-logo" />
          <img src="/portfolio/images/logos/dart.svg" alt="Dart" class="marquee-logo" />
          <img src="/portfolio/images/logos/firebase.svg" alt="Firebase" class="marquee-logo" />
          <img src="/portfolio/images/logos/codemagic.svg" alt="Codemagic" class="marquee-logo" />
          <img src="/portfolio/images/logos/gemini.svg" alt="Gemini AI" class="marquee-logo" />
          <img src="/portfolio/images/logos/claude.svg" alt="Claude" class="marquee-logo" />
          <img src="/portfolio/images/logos/typescript.svg" alt="TypeScript" class="marquee-logo" />
          <img src="/portfolio/images/logos/revenuecat.svg" alt="RevenueCat" class="marquee-logo" />
          <img src="/portfolio/images/logos/astro-icon-dark.svg" alt="Astro" class="marquee-logo" />
          <img src="/portfolio/images/logos/stripe.svg" alt="Stripe" class="marquee-logo" />
          <img src="/portfolio/images/logos/git.svg" alt="Git" class="marquee-logo" />
        </div>
        <div class="marquee-set" aria-hidden="true">
          <img src="/portfolio/images/logos/flutter.svg" alt="" class="marquee-logo" />
          <img src="/portfolio/images/logos/dart.svg" alt="" class="marquee-logo" />
          <img src="/portfolio/images/logos/firebase.svg" alt="" class="marquee-logo" />
          <img src="/portfolio/images/logos/codemagic.svg" alt="" class="marquee-logo" />
          <img src="/portfolio/images/logos/gemini.svg" alt="" class="marquee-logo" />
          <img src="/portfolio/images/logos/claude.svg" alt="" class="marquee-logo" />
          <img src="/portfolio/images/logos/typescript.svg" alt="" class="marquee-logo" />
          <img src="/portfolio/images/logos/revenuecat.svg" alt="" class="marquee-logo" />
          <img src="/portfolio/images/logos/astro-icon-dark.svg" alt="" class="marquee-logo" />
          <img src="/portfolio/images/logos/stripe.svg" alt="" class="marquee-logo" />
          <img src="/portfolio/images/logos/git.svg" alt="" class="marquee-logo" />
        </div>
      </div>
    </div>

    </div><!-- end #panel-process -->

  </div>
</section>

<style>
  .marquee-container {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee-scroll 30s linear infinite;
  }

  .marquee-container:hover .marquee-track {
    animation-play-state: paused;
  }

  .marquee-set {
    display: flex;
    align-items: center;
    gap: clamp(2rem, 3vw, 3.5rem);
    padding-right: clamp(2rem, 3vw, 3.5rem);
  }

  .marquee-logo {
    height: clamp(1.1rem, 1.5vw, 1.4rem);
    width: auto;
    opacity: 0.4;
    filter: grayscale(1);
    transition: opacity 0.3s, filter 0.3s;
    flex-shrink: 0;
  }

  .marquee-logo:hover {
    opacity: 1;
    filter: grayscale(0);
  }

  .marquee-logo[src*="revenuecat"] {
    transform: translateY(2px);
  }

  /* Wordmark logos — slightly taller but capped */
  .marquee-logo[src*="flutter"],
  .marquee-logo[src*="stripe"] {
    height: clamp(1.3rem, 1.8vw, 1.6rem);
  }

  /* Long wordmarks — cap harder */
  .marquee-logo[src*="codemagic"],
  .marquee-logo[src*="revenuecat"] {
    height: clamp(1.1rem, 1.4vw, 1.3rem);
  }

  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
