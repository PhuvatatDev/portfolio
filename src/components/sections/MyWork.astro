---
// My Work — Cream card with 4 process steps in a horizontal row
// Illustrations converge here from the Hero via GSAP ScrollTrigger
---

<section id="my-work" class="relative z-10" style="height: 400vh;">
  <!-- Cream card — FIXED, centered, horizontal rectangle -->
  <div id="process-card" class="fixed opacity-0 z-20" style="top: 50%; left: 50%; transform: translate(-50%, -50%); width: 85vw; max-width: 1100px; padding: 2.5vw 3vw; background-color: #F5F3EF; border-radius: 1rem;">

    <!-- Section label -->
    <p class="font-mono text-charcoal/40 mb-6" style="font-size: clamp(0.7rem, 0.8vw, 0.8rem); letter-spacing: 0.1em;">
      [ how I work ]
    </p>

    <!-- 4 steps — horizontal row -->
    <div class="flex justify-between items-start gap-4">

      <!-- Step 1: Idea -->
      <div id="process-slot-idea" class="flex flex-col items-center text-center flex-1">
        <div class="process-illus-slot" style="width: 8vw; height: 8vw; max-width: 120px; max-height: 120px;"></div>
        <h3 class="font-serif font-bold text-charcoal mt-3" style="font-size: clamp(0.95rem, 1.1vw, 1.2rem);">Idea</h3>
        <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, 0.7vw, 0.75rem);">You have an app idea</p>
      </div>

      <!-- Arrow -->
      <div class="flex items-center pt-8 text-charcoal/20" style="font-size: clamp(1rem, 1.5vw, 1.5rem);">→</div>

      <!-- Step 2: Discussion -->
      <div id="process-slot-discussion" class="flex flex-col items-center text-center flex-1">
        <div class="process-illus-slot" style="width: 8vw; height: 8vw; max-width: 120px; max-height: 120px;"></div>
        <h3 class="font-serif font-bold text-charcoal mt-3" style="font-size: clamp(0.95rem, 1.1vw, 1.2rem);">Discussion</h3>
        <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, 0.7vw, 0.75rem);">We align on scope & goals</p>
      </div>

      <!-- Arrow -->
      <div class="flex items-center pt-8 text-charcoal/20" style="font-size: clamp(1rem, 1.5vw, 1.5rem);">→</div>

      <!-- Step 3: Build -->
      <div id="process-slot-build" class="flex flex-col items-center text-center flex-1">
        <div class="process-illus-slot" style="width: 8vw; height: 8vw; max-width: 120px; max-height: 120px;"></div>
        <h3 class="font-serif font-bold text-charcoal mt-3" style="font-size: clamp(0.95rem, 1.1vw, 1.2rem);">Build</h3>
        <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, 0.7vw, 0.75rem);">I turn it into a real app</p>
        <!-- Tech badges -->
        <div class="flex flex-wrap gap-1.5 mt-2 justify-center process-badges opacity-0">
          <span class="font-mono text-charcoal/60 px-1.5 py-0.5 border border-charcoal/15 rounded" style="font-size: clamp(0.55rem, 0.6vw, 0.65rem);">[ Flutter ]</span>
          <span class="font-mono text-charcoal/60 px-1.5 py-0.5 border border-charcoal/15 rounded" style="font-size: clamp(0.55rem, 0.6vw, 0.65rem);">[ Firebase ]</span>
          <span class="font-mono text-charcoal/60 px-1.5 py-0.5 border border-charcoal/15 rounded" style="font-size: clamp(0.55rem, 0.6vw, 0.65rem);">[ Claude Code ]</span>
          <span class="font-mono text-charcoal/60 px-1.5 py-0.5 border border-charcoal/15 rounded" style="font-size: clamp(0.55rem, 0.6vw, 0.65rem);">[ Clean Archi ]</span>
        </div>
      </div>

      <!-- Arrow -->
      <div class="flex items-center pt-8 text-charcoal/20" style="font-size: clamp(1rem, 1.5vw, 1.5rem);">→</div>

      <!-- Step 4: Live -->
      <div id="process-slot-live" class="flex flex-col items-center text-center flex-1">
        <div class="process-illus-slot" style="width: 8vw; height: 8vw; max-width: 120px; max-height: 120px;"></div>
        <h3 class="font-serif font-bold text-charcoal mt-3" style="font-size: clamp(0.95rem, 1.1vw, 1.2rem);">Live</h3>
        <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, 0.7vw, 0.75rem);">Published on the stores</p>
        <!-- Tech badges -->
        <div class="flex flex-wrap gap-1.5 mt-2 justify-center process-badges opacity-0">
          <span class="font-mono text-charcoal/60 px-1.5 py-0.5 border border-charcoal/15 rounded" style="font-size: clamp(0.55rem, 0.6vw, 0.65rem);">[ Google Play ]</span>
          <span class="font-mono text-charcoal/60 px-1.5 py-0.5 border border-charcoal/15 rounded" style="font-size: clamp(0.55rem, 0.6vw, 0.65rem);">[ App Store ]</span>
          <span class="font-mono text-charcoal/60 px-1.5 py-0.5 border border-charcoal/15 rounded" style="font-size: clamp(0.55rem, 0.6vw, 0.65rem);">[ Web ]</span>
        </div>
      </div>

    </div>
  </div>
</section>
