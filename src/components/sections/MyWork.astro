---
// My Work — Process Card only
// Illustrations converge into cream card with 4 steps (Idea → Discussion → Build → Live)
// Card exits upward, then phone+tech arrives
import Marquee from '../ui/Marquee.astro';
import { techLogos } from '../../data/tech-logos';
---

<section id="my-work" class="relative z-10" style="height: 200vh;">

  <!-- Vertical section label — fixed, synced with process-card via GSAP -->
  <div id="process-label" class="section-label-wrapper section-label-card">
    <span class="section-label-vertical">[ how it works ]</span>
  </div>

  <!-- CreamPanel — FIXED, position managed by GSAP (xPercent/yPercent for centering) -->
  <div id="process-card" class="fixed opacity-0 z-20" style="top: 55%; left: 50%; width: 85vw; max-width: 1100px; background-color: #F5F3EF; border-radius: 1rem; overflow: hidden;">

    <div style="padding: min(2.5vw, 4vh) min(3vw, 5vh) min(1.5vw, 2.5vh);">

      <!-- 4 steps — horizontal row -->
      <div class="flex justify-between items-start gap-4">

      <!-- Step 1: Idea -->
      <div id="process-slot-idea" class="flex flex-col items-center text-center flex-1">
        <div class="process-illus-slot" style="width: min(10vw, 16vh); height: min(10vw, 16vh); max-width: 160px; max-height: 160px;"></div>
        <h3 class="font-serif font-bold text-charcoal mt-3" style="font-size: clamp(0.95rem, min(1.1vw, 1.8vh), 1.2rem);">Idea</h3>
        <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, min(0.7vw, 1.1vh), 0.75rem);">You have an app idea</p>
      </div>

      <!-- Arrow -->
      <div class="flex items-center text-charcoal/20" style="font-size: clamp(1rem, min(1.5vw, 2.5vh), 1.5rem); padding-top: min(5vw, 7vh);">→</div>

      <!-- Step 2: Discussion -->
      <div id="process-slot-discussion" class="flex flex-col items-center text-center flex-1">
        <div class="process-illus-slot" style="width: min(10vw, 16vh); height: min(10vw, 16vh); max-width: 160px; max-height: 160px;"></div>
        <h3 class="font-serif font-bold text-charcoal mt-3" style="font-size: clamp(0.95rem, min(1.1vw, 1.8vh), 1.2rem);">Discussion</h3>
        <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, min(0.7vw, 1.1vh), 0.75rem);">We align on scope & goals</p>
      </div>

      <!-- Arrow -->
      <div class="flex items-center text-charcoal/20" style="font-size: clamp(1rem, min(1.5vw, 2.5vh), 1.5rem); padding-top: min(5vw, 7vh);">→</div>

      <!-- Step 3: Build -->
      <div id="process-slot-build" class="flex flex-col items-center text-center flex-1">
        <div class="process-illus-slot" style="width: min(10vw, 16vh); height: min(10vw, 16vh); max-width: 160px; max-height: 160px;"></div>
        <h3 class="font-serif font-bold text-charcoal mt-3" style="font-size: clamp(0.95rem, min(1.1vw, 1.8vh), 1.2rem);">Build</h3>
        <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, min(0.7vw, 1.1vh), 0.75rem);">I turn it into a real app</p>
      </div>

      <!-- Arrow -->
      <div class="flex items-center text-charcoal/20" style="font-size: clamp(1rem, min(1.5vw, 2.5vh), 1.5rem); padding-top: min(5vw, 7vh);">→</div>

      <!-- Step 4: Live -->
      <div id="process-slot-live" class="flex flex-col items-center text-center flex-1">
        <div class="process-illus-slot" style="width: min(10vw, 16vh); height: min(10vw, 16vh); max-width: 160px; max-height: 160px;"></div>
        <h3 class="font-serif font-bold text-charcoal mt-3" style="font-size: clamp(0.95rem, min(1.1vw, 1.8vh), 1.2rem);">Live</h3>
        <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, min(0.7vw, 1.1vh), 0.75rem);">Published on the stores</p>
      </div>

    </div>

    <!-- Tech stack label + marquee -->
    <p class="font-mono text-charcoal/30 mt-6 border-t border-charcoal/10 pt-4 mb-3" style="font-size: clamp(0.6rem, min(0.7vw, 1.1vh), 0.7rem); letter-spacing: 0.08em;">[ what I use ]</p>
    <Marquee logos={techLogos} speed="30s" repeat={2} />

    </div>

  </div>
</section>

