        <p class="font-mono text-charcoal/60 mb-4" style="font-size: clamp(0.75rem, 0.85vw, 0.9rem); line-height: 1.7;">
          The app stays fast and responsive. Every action — drawing cards, saving, loading — shows clear feedback: loading, success, or error. No frozen screens, no lost data. Under the hood: Cubit pattern with immutable states. Each feature has its own Cubit. Use cases are injected, keeping everything testable and independent.
        </p>
        <pre class="font-mono bg-charcoal/5 rounded p-3 mb-4" style="font-size: clamp(0.55rem, 0.6vw, 0.65rem); line-height: 1.5; color: #6B6B5A;" set:html={`<span style="color:#5C7A3A">class</span> <span style="color:#1A1A1A;font-weight:600">DrawCubit</span> <span style="color:#5C7A3A">extends</span> <span style="color:#C4841D">Cubit</span>&lt;<span style="color:#C4841D">DrawState</span>&gt; {
  <span style="color:#5C7A3A">final</span> <span style="color:#C4841D">DrawCardsUseCase</span> _drawCards;
  <span style="color:#5C7A3A">final</span> <span style="color:#C4841D">SaveDrawUseCase</span> _saveDraw;
  <span style="color:#8A8A7A">// ... 7 more injected use cases</span>

  <span style="color:#C4841D">Future</span>&lt;<span style="color:#5C7A3A">void</span>&gt; <span style="color:#1A1A1A">drawCards</span>() <span style="color:#5C7A3A">async</span> {
    emit(<span style="color:#C4841D">DrawDrawingCards</span>(_currentConfig!));

    <span style="color:#5C7A3A">try</span> {
      <span style="color:#5C7A3A">final</span> result = <span style="color:#5C7A3A">await</span> _drawCards.execute(_currentConfig!);
      emit(<span style="color:#C4841D">DrawCardsDrawn</span>(
        config: _currentConfig!,
        drawResult: result,
      ));
    } <span style="color:#5C7A3A">on</span> <span style="color:#C4841D">AppException</span> <span style="color:#5C7A3A">catch</span> (e) {
      emit(<span style="color:#C4841D">DrawError</span>(e.getUserMessage()));
    }
  }
}`} />
