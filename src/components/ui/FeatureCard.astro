---
interface Props {
  title: string;
  description: string;
  featureId: string;
  colSpan?: 1 | 2;
}
const { title, description, featureId, colSpan = 1 } = Astro.props;
---

<div class:list={['feature-card group', colSpan === 2 && 'col-span-2']} data-feature={featureId}>
  <div class="flex justify-between items-start">
    <h3 class="font-serif font-bold text-charcoal" style="font-size: clamp(0.8rem, 0.9vw, 0.95rem);">
      {title}
    </h3>
    <span class="font-mono text-charcoal/20 group-hover:text-charcoal/50 transition-colors shrink-0 ml-2" style="font-size: 0.75rem;">
      →
    </span>
  </div>
  <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, 0.65vw, 0.72rem); line-height: 1.5;">
    {description}
  </p>
  <div class="mt-3">
    <slot />
  </div>
</div>

<style>
  .feature-card {
    border: 1px solid rgba(26, 26, 26, 0.08);
    border-radius: 0.5rem;
    padding: clamp(0.6rem, 0.8vw, 0.85rem);
    background: rgba(255, 255, 255, 0.3);
    cursor: pointer;
    transform: translateY(0);
    transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
                border-color 0.25s,
                box-shadow 0.25s,
                background-color 0.25s;
    will-change: transform;
  }
  .feature-card:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.55);
    border-color: rgba(26, 26, 26, 0.2);
    box-shadow:
      0 14px 28px -10px rgba(26, 26, 26, 0.18),
      0 6px 12px -4px rgba(26, 26, 26, 0.1),
      0 2px 4px -1px rgba(26, 26, 26, 0.06);
  }
</style>
