---
interface Props {
  title: string;
  description: string;
  colSpan?: 1 | 2;
}
const { title, description, colSpan = 1 } = Astro.props;
---

<div class:list={['feature-card', colSpan === 2 && 'col-span-2']}>
  <h3 class="font-serif font-bold text-charcoal" style="font-size: clamp(0.8rem, 0.9vw, 0.95rem);">
    {title}
  </h3>
  <p class="font-mono text-charcoal/50 mt-1" style="font-size: clamp(0.6rem, 0.65vw, 0.72rem); line-height: 1.5;">
    {description}
  </p>
  <div class="mt-3">
    <slot />
  </div>
</div>

<style>
  .feature-card {
    border: 1px solid rgba(26, 26, 26, 0.08);
    border-radius: 0.5rem;
    padding: clamp(0.75rem, 1vw, 1rem);
    background: rgba(255, 255, 255, 0.3);
  }
</style>
