---
// TechCard — Individual technical card for the MindTarot panel
// Used in two contexts:
// 1. Inside the CreamPanel tech grid (Phase 4) — clickable, shows detail
// 2. Scattered in the outro/contact section (Phase 5) — decorative, dispersed
//
// Integration:
// - In Phase 4: arranged in grid inside CreamPanel, managed by feature-panel.ts
// - In Phase 5: absolute positioned, scattered via GSAP, purely visual
//
// Props:
// - title: card title
// - description: short description
// - featureId: unique ID for click-to-detail linking
// - scattered: if true, renders in "scattered" mode (no click, decorative)

interface Props {
  title: string;
  description: string;
  featureId: string;
  scattered?: boolean;
  colSpan?: number;
}

const { title, description, featureId, scattered = false, colSpan = 1 } = Astro.props;
---

{scattered ? (
  <!-- Scattered mode: decorative card for outro -->
  <div class="tech-card-scattered bg-cream rounded-lg p-3 shadow-sm pointer-events-none select-none"
       data-card-id={featureId}
       style={`width: clamp(140px, 12vw, 180px);`}>
    <p class="font-mono font-bold text-charcoal/70 mb-1" style="font-size: clamp(0.6rem, 0.7vw, 0.75rem);">
      {title}
    </p>
    <p class="font-mono text-charcoal/40" style="font-size: clamp(0.5rem, 0.55vw, 0.6rem); line-height: 1.5;">
      {description}
    </p>
  </div>
) : (
  <!-- Grid mode: clickable card inside panel -->
  <div class={`feature-card cursor-pointer rounded-lg bg-charcoal/[0.03] hover:bg-charcoal/[0.06] transition-colors p-3 ${colSpan === 2 ? 'col-span-2' : ''}`}
       data-feature={featureId}>
    <p class="font-mono font-bold text-charcoal/70 mb-1" style="font-size: clamp(0.6rem, 0.7vw, 0.75rem);">
      {title}
    </p>
    <p class="font-mono text-charcoal/40 mb-2" style="font-size: clamp(0.5rem, 0.55vw, 0.6rem); line-height: 1.5;">
      {description}
    </p>
    <slot />
  </div>
)}
