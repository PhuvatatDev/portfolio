---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeGrid from '../components/sections/CodeGrid.astro';
import Header from '../components/layout/Header.astro';
import Hero from '../components/sections/Hero.astro';
import MyWork from '../components/sections/MyWork.astro';
import PhoneShowcase from '../components/sections/PhoneShowcase.astro';
import ContactHero from '../components/sections/ContactHero.astro';
---

<BaseLayout>
  <CodeGrid />
  <Header />
  <Hero />
  <MyWork />
  <PhoneShowcase />
  <ContactHero />

  <!-- Phone container — fixed, centered, starts below viewport -->
  <!-- Rises via GSAP, then shifts left while CreamPanel morphs to right side -->
  <div id="phone-container" class="fixed z-30 pointer-events-none" style="left: 50%; top: 55%;">
    <div class="relative" style="width: 22vw; max-width: 340px;">
      <!-- Screen area -->
      <div id="phone-screen" class="absolute overflow-hidden" style="top: 9.4%; left: 11.7%; right: 9.0%; bottom: 11.4%; border-radius: 1.5vw; background: #F5F3EF;">
        <video
          id="phone-video"
          class="absolute inset-0 w-full h-full object-cover object-top"
          autoplay
          muted
          playsinline
          preload="auto"
          data-playlist="/portfolio/video/login.mp4,/portfolio/video/payment.mp4,/portfolio/video/navigation.mp4"
        >
          <source src="/portfolio/video/login.mp4" type="video/mp4" />
        </video>
      </div>
      <!-- Phone frame (on top of screen content) -->
      <img src="/portfolio/images/phone-frame.png" alt="" class="w-full relative z-10" />
    </div>
  </div>
</BaseLayout>

<script>
  import { initScrollController } from '../components/animations/scroll-controller';
  import { initFeaturePanel } from '../components/animations/feature-panel';
  initScrollController();
  initFeaturePanel();

  // Smooth scroll navigation — GSAP-compatible (no CSS scroll-behavior)
  document.querySelectorAll('a.nav-link').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = (link as HTMLAnchorElement).getAttribute('href');
      if (!href || !href.startsWith('#')) return;
      const target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Tech panel scroll — intercept wheel on the card itself when tech is visible
  const processCard = document.getElementById('process-card');
  const techScrollEl = document.getElementById('panel-tech-scroll');
  const techPanel = document.getElementById('panel-tech');
  if (processCard && techScrollEl && techPanel) {
    processCard.addEventListener('wheel', (e) => {
      // Only when tech panel is active (opacity > 0 and pointer-events auto)
      if (techPanel.style.pointerEvents === 'none') return;
      const opacity = parseFloat(getComputedStyle(techPanel).opacity);
      if (opacity < 0.5) return;

      const { scrollTop, scrollHeight, clientHeight } = techScrollEl;
      const canScrollUp = scrollTop > 0;
      const canScrollDown = scrollTop + clientHeight < scrollHeight - 1;

      if ((e.deltaY < 0 && canScrollUp) || (e.deltaY > 0 && canScrollDown)) {
        e.preventDefault();
        e.stopPropagation();
        techScrollEl.scrollTop += e.deltaY;
      }
    }, { passive: false });
  }

  // Phone video playlist — cycles through videos with fade transitions
  const video = document.getElementById('phone-video') as HTMLVideoElement;
  if (video) {
    const playlist = video.dataset.playlist?.split(',') ?? [];
    let currentIndex = 0;
    video.style.transition = 'opacity 0.5s ease';

    video.addEventListener('ended', () => {
      // Fade out
      video.style.opacity = '0';
      setTimeout(() => {
        currentIndex = (currentIndex + 1) % playlist.length;
        video.src = playlist[currentIndex];
        video.play();
        // Fade in
        video.style.opacity = '1';
      }, 500);
    });
  }
</script>
