---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeGrid from '../components/sections/CodeGrid.astro';
import Header from '../components/layout/Header.astro';
import Hero from '../components/sections/Hero.astro';
import MyWork from '../components/sections/MyWork.astro';
import PhoneShowcase from '../components/sections/PhoneShowcase.astro';
---

<BaseLayout>
  <CodeGrid />
  <Header />
  <Hero />
  <MyWork />
  <PhoneShowcase />

  <!-- Phone container — fixed, centered, starts below viewport -->
  <!-- Rises via GSAP, then shifts left to make room for showcase panel -->
  <div id="phone-container" class="fixed z-30 pointer-events-none" style="left: 50%; top: 55%;">
    <div class="relative" style="width: 25vw; max-width: 360px;">
      <!-- Screen area -->
      <div id="phone-screen" class="absolute overflow-hidden" style="top: 9.4%; left: 11.7%; right: 9.0%; bottom: 11.4%; border-radius: 2.2vw; background: #000;">
        <!-- Video placeholder — will be replaced with screen recording -->
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="font-mono text-white/20" style="font-size: 0.6rem;">[ video ]</span>
        </div>
      </div>
      <!-- Phone frame (on top of screen content) -->
      <img src="/portfolio/images/phone-frame.png" alt="" class="w-full relative z-10" />
    </div>
  </div>
</BaseLayout>

<script>
  import { initScrollController } from '../components/animations/scroll-controller';
  import { initFeaturePanel } from '../components/animations/feature-panel';
  initScrollController();
  initFeaturePanel();
</script>
