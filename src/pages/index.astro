---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeGrid from '../components/sections/CodeGrid.astro';
import Header from '../components/layout/Header.astro';
import Hero from '../components/sections/Hero.astro';
import MyWork from '../components/sections/MyWork.astro';
import PhoneShowcase from '../components/sections/PhoneShowcase.astro';
import TechContent from '../components/sections/TechContent.astro';
import RepoSection from '../components/sections/RepoSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import ContactHero from '../components/sections/ContactHero.astro';
---

<BaseLayout>
  <CodeGrid />
  <Header />
  <Hero />
  <MyWork />
  <PhoneShowcase />
  <RepoSection />
  <AboutSection />
  <ContactHero />

  <!-- Phone + Tech panel — centered flex wrapper, phone and panel as a unified block -->
  <div id="phone-panel-wrapper" class="fixed z-20" style="inset: 0; padding-top: clamp(75px, 10vh, 110px); display: flex; align-items: center; justify-content: center; pointer-events: none;">
    <!-- Mobile title — fixed in wrapper, independent from phone shift.
         Positioned above center via absolute, stays still when phone moves left. -->
    <div id="phone-mobile-title" style="position: absolute; left: 8%; top: 16%; opacity: 0; background-color: #F5F3EF; border-radius: 0.75rem; padding: clamp(0.75rem, 2.5vw, 1rem); border: 1px solid rgba(26,26,26,0.1); box-shadow: 0 14px 28px -8px rgba(26,26,26,0.25), 0 8px 14px -4px rgba(26,26,26,0.14), 0 3px 6px -1px rgba(26,26,26,0.08);">
      <h2 class="font-serif font-bold text-charcoal" style="font-size: clamp(1.2rem, 5vw, 1.6rem); line-height: 1.1;">MindTarot</h2>
      <p class="font-mono text-charcoal/50" style="font-size: clamp(0.75rem, 2.5vw, 0.9rem); margin-top: 0.25rem;">Built from scratch to store, live in production.</p>
    </div>
    <!-- Inner wrapper — sized to content so tech-label's right:calc(100%+…) works -->
    <div style="position: relative; display: flex; align-items: center; gap: clamp(30px, 3.5vw, 70px);">
      <!-- Vertical section label — absolute, positioned to the left of the phone.
           Vertical centering handled by GSAP yPercent:-50 (so `y` tween stays additive). -->
      <div id="tech-label" style="position: absolute; right: calc(100% + 1.25rem); top: 50%; opacity: 0; pointer-events: none;">
        <span class="section-label-vertical">[ featured project ]</span>
      </div>
      <!-- Phone -->
      <div id="phone-container" class="opacity-0" style="pointer-events: none;">
        <div class="relative" style="width: clamp(260px, 20vw, 330px);">
          <div class="absolute overflow-hidden" style="top: 9.4%; left: 11.7%; right: 9.0%; bottom: 11.4%; border-radius: 1.5vw; background: #F5F3EF;">
            <video
              id="phone-video"
              class="absolute inset-0 w-full h-full object-cover object-top"
              autoplay
              muted
              playsinline
              preload="auto"
              data-playlist="/portfolio/video/login.mp4,/portfolio/video/payment.mp4,/portfolio/video/navigation.mp4"
            >
              <source src="/portfolio/video/login.mp4" type="video/mp4" />
            </video>
          </div>
          <img src="/portfolio/images/phone-frame.png" alt="" class="w-full relative z-10" loading="lazy" decoding="async" />
        </div>
      </div>

      <!-- Tech panel -->
      <div id="tech-panel-container" class="opacity-0" style="width: clamp(580px, min(60vw, 100vh), 820px); height: fit-content; max-height: clamp(400px, 85vh, 860px); background-color: #F5F3EF; border-radius: 1rem; overflow: hidden; pointer-events: auto;">
        <TechContent />
      </div>
    </div>
  </div>
  <!-- Mobile fullscreen card modal — shows desktop detail content on tap -->
  <div id="mobile-card-modal" class="fixed inset-0 z-50" style="display: none;">
    <div style="height: 100%; overflow-y: auto; -webkit-overflow-scrolling: touch; background-color: #F5F3EF; padding: 1.5rem;">
      <button id="modal-close" class="font-mono text-charcoal/50 cursor-pointer mb-6 flex items-center gap-2" style="font-size: 0.9rem;">
        <span>←</span> [ back ]
      </button>
      <div id="modal-content"></div>
    </div>
  </div>
</BaseLayout>

<script>
  import { initScrollController } from '../components/animations/scroll-controller';
  import { initFeaturePanel } from '../components/animations/feature-panel';
  initScrollController();
  initFeaturePanel();

  // Reload on breakpoint cross — JS init is one-shot, CSS adapts but
  // handlers (phone tap, modal) need re-init when crossing 1180px.
  const mql = window.matchMedia('(max-width: 1179px)');
  mql.addEventListener('change', () => location.reload());

  // Smooth scroll navigation — GSAP-compatible (no CSS scroll-behavior)
  document.querySelectorAll('a.nav-link').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = (link as HTMLAnchorElement).getAttribute('href');
      if (!href || !href.startsWith('#')) return;
      const target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Mobile: tap phone → scale up + slide to center (above cards)
  //         scroll or re-tap → shrink back to original position
  if (window.matchMedia('(max-width: 1179px)').matches) {
    const phoneContainer = document.getElementById('phone-container');
    const phoneWrapper = document.getElementById('phone-panel-wrapper');
    if (phoneContainer && phoneWrapper) {
      phoneContainer.style.pointerEvents = 'auto';
      phoneContainer.style.cursor = 'pointer';
      let phoneInFront = false;
      let phoneTimer: ReturnType<typeof setTimeout> | null = null;

      const focusPhone = () => {
        if (phoneTimer) clearTimeout(phoneTimer);
        phoneInFront = true;
        phoneContainer.style.opacity = '0';
        phoneTimer = setTimeout(() => {
          phoneTimer = null;
          phoneWrapper.style.zIndex = '30';
          const rect = phoneContainer.getBoundingClientRect();
          const offsetX = (window.innerWidth / 2) - (rect.left + rect.width / 2);
          phoneContainer.style.translate = `${offsetX}px 0`;
          phoneContainer.classList.add('phone-focused');
          requestAnimationFrame(() => { phoneContainer.style.opacity = '1'; });
        }, 300);
      };

      const unfocusPhone = () => {
        if (phoneTimer) clearTimeout(phoneTimer);
        phoneInFront = false;
        phoneContainer.style.opacity = '0';
        phoneTimer = setTimeout(() => {
          phoneTimer = null;
          phoneWrapper.style.zIndex = '20';
          phoneContainer.style.translate = '';
          phoneContainer.classList.remove('phone-focused');
          requestAnimationFrame(() => { phoneContainer.style.opacity = '1'; });
        }, 300);
      };

      phoneContainer.addEventListener('click', () => {
        phoneInFront ? unfocusPhone() : focusPhone();
      });

      window.addEventListener('scroll', () => {
        if (phoneInFront) unfocusPhone();
      }, { passive: true });
    }
  }

  // Mobile card modal — fullscreen detail view on tap
  if (window.matchMedia('(max-width: 1179px)').matches) {
    const modal = document.getElementById('mobile-card-modal');
    const modalContent = document.getElementById('modal-content');
    const modalClose = document.getElementById('modal-close');
    let savedScrollY = 0;

    const openModal = (featureId: string) => {
      const detailDiv = document.querySelector(`.feature-detail[data-detail="${featureId}"]`);
      if (!detailDiv || !modal || !modalContent) return;

      savedScrollY = window.scrollY;
      modalContent.innerHTML = detailDiv.innerHTML;
      modal.style.display = '';
      document.documentElement.style.overflow = 'hidden';
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => modal.classList.add('modal-open'));
    };

    const closeModal = () => {
      if (!modal) return;
      modal.classList.remove('modal-open');
      setTimeout(() => {
        modal.style.display = 'none';
        modalContent!.innerHTML = '';
        document.documentElement.style.overflow = '';
        document.body.style.overflow = '';
        window.scrollTo(0, savedScrollY);
      }, 300);
    };

    // Override MobileShowcase click handlers — open modal instead of expand
    document.querySelectorAll('.mobile-feature-card[data-mobile-feature]').forEach(card => {
      card.addEventListener('click', (e) => {
        e.stopImmediatePropagation();
        const featureId = (card as HTMLElement).dataset.mobileFeature;
        if (featureId) openModal(featureId);
      }, true); // capture phase to override MobileShowcase handler
    });

    modalClose?.addEventListener('click', closeModal);

    // Close on backdrop tap (outside content)
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
  }

  // Phone video playlist — cycles through videos with fade transitions
  const video = document.getElementById('phone-video') as HTMLVideoElement;
  if (video) {
    const playlist = video.dataset.playlist?.split(',') ?? [];
    let currentIndex = 0;
    video.style.transition = 'opacity 0.5s ease';

    video.addEventListener('ended', () => {
      video.style.opacity = '0';
      setTimeout(() => {
        currentIndex = (currentIndex + 1) % playlist.length;
        video.src = playlist[currentIndex];
        video.play().catch(() => {});
        video.style.opacity = '1';
      }, 500);
    });
  }
</script>
