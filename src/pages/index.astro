---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeGrid from '../components/sections/CodeGrid.astro';
import Header from '../components/layout/Header.astro';
import Hero from '../components/sections/Hero.astro';
import MyWork from '../components/sections/MyWork.astro';
import PhoneShowcase from '../components/sections/PhoneShowcase.astro';
import TechContent from '../components/sections/TechContent.astro';
import RepoSection from '../components/sections/RepoSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import ContactHero from '../components/sections/ContactHero.astro';
---

<BaseLayout>
  <CodeGrid />
  <Header />
  <Hero />
  <MyWork />
  <PhoneShowcase />
  <RepoSection />
  <AboutSection />
  <ContactHero />

  <!-- Phone container — fixed, already positioned left -->
  <div id="phone-container" class="fixed z-30 pointer-events-none opacity-0" style="left: 25%; top: 50%; transform: translateY(-50%);">
    <div class="relative" style="width: 22vw; max-width: 340px;">
      <!-- Screen area -->
      <div id="phone-screen" class="absolute overflow-hidden" style="top: 9.4%; left: 11.7%; right: 9.0%; bottom: 11.4%; border-radius: 1.5vw; background: #F5F3EF;">
        <video
          id="phone-video"
          class="absolute inset-0 w-full h-full object-cover object-top"
          autoplay
          muted
          playsinline
          preload="auto"
          data-playlist="/portfolio/video/login.mp4,/portfolio/video/payment.mp4,/portfolio/video/navigation.mp4"
        >
          <source src="/portfolio/video/login.mp4" type="video/mp4" />
        </video>
      </div>
      <!-- Phone frame (on top of screen content) -->
      <img src="/portfolio/images/phone-frame.png" alt="" class="w-full relative z-10" />
    </div>
  </div>

  <!-- Tech panel — fixed, right of phone, cream card with scrollable content -->
  <div id="tech-panel-container" class="fixed z-20 opacity-0" style="left: 40%; top: 50%; width: calc(57% - 2rem); max-width: 700px; height: 80vh; max-height: 750px; background-color: #F5F3EF; border-radius: 1rem; overflow: hidden; transform: translateY(-50%);">
    <TechContent />
  </div>
</BaseLayout>

<script>
  import { initScrollController } from '../components/animations/scroll-controller';
  import { initFeaturePanel } from '../components/animations/feature-panel';
  initScrollController();
  initFeaturePanel();

  // Smooth scroll navigation — GSAP-compatible (no CSS scroll-behavior)
  document.querySelectorAll('a.nav-link').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = (link as HTMLAnchorElement).getAttribute('href');
      if (!href || !href.startsWith('#')) return;
      const target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Tech panel scroll — intercept wheel when cursor is over the tech panel
  const techContainer = document.getElementById('tech-panel-container');
  const techScrollEl = document.getElementById('panel-tech-scroll');
  if (techContainer && techScrollEl) {
    window.addEventListener('wheel', (e) => {
      // Only when tech panel is visible
      const opacity = parseFloat(getComputedStyle(techContainer).opacity);
      if (opacity < 0.5) return;

      // Only when cursor is over the panel
      const rect = techContainer.getBoundingClientRect();
      if (e.clientX < rect.left || e.clientX > rect.right ||
          e.clientY < rect.top || e.clientY > rect.bottom) return;

      const { scrollTop, scrollHeight, clientHeight } = techScrollEl;
      const atTop = scrollTop <= 0;
      const atBottom = scrollTop + clientHeight >= scrollHeight - 1;

      // Intercept: scroll the inner container instead of the page
      if ((e.deltaY > 0 && !atBottom) || (e.deltaY < 0 && !atTop)) {
        e.preventDefault();
        techScrollEl.scrollTop += e.deltaY;
      }
    }, { passive: false });
  }

  // Phone video playlist — cycles through videos with fade transitions
  const video = document.getElementById('phone-video') as HTMLVideoElement;
  if (video) {
    const playlist = video.dataset.playlist?.split(',') ?? [];
    let currentIndex = 0;
    video.style.transition = 'opacity 0.5s ease';

    video.addEventListener('ended', () => {
      video.style.opacity = '0';
      setTimeout(() => {
        currentIndex = (currentIndex + 1) % playlist.length;
        video.src = playlist[currentIndex];
        video.play();
        video.style.opacity = '1';
      }, 500);
    });
  }
</script>
